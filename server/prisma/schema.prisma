generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
}

model User {
  id                   String     @id @default(cuid())
  firstName            String
  lastName             String
  email                String     @unique
  password             String
  dateOfBirth          DateTime
  passwordResetToken   String?    @db.VarChar(64)
  passwordResetExpires DateTime?
  sessions             Session[]
  files                File[]
  shares               FileShare[] @relation("ownerShares")
  profileImage         String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
}

model File {
  id               String    @id @default(cuid())
  userId           String
  originalFileName String
  storedFileName   String
  cloudinaryPublicId String?  @unique
  cloudinaryResourceType String?
  cloudinaryUrl    String?
  // storage backend: 'cloudinary' or 'supabase'
  storageBackend   String?
  // for supabase-stored objects: path within bucket
  supabasePath     String?
  fileSize         BigInt
  mimeType         String
  isTrashed        Boolean   @default(false)
  trashedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  owner            User      @relation(fields: [userId], references: [id])
  shares           FileShare[]
  fileContent      FileContent?
  fileEmbedding    FileEmbedding?
}

model FileContent {
  id            String   @id @default(cuid())
  fileId        String   @unique
  content       String   @db.Text
  searchIndex   String?  @db.Text
  wordCount     Int?
  pageCount     Int?
  ocrConfidence Float?
  language      String?
  extractedAt   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  file          File     @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
}

model FileEmbedding {
  id             String   @id @default(cuid())
  fileId         String   @unique
  model          String
  inputType      String
  embeddingKind  String
  caption        String?  @db.Text
  labels         Json?
  dimensions     Int?
  vector         Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  file           File     @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
}

model FileShare {
  id             String   @id @default(cuid())
  fileId         String
  ownerId        String
  recipientEmail String
  token          String   @unique
  message        String?
  expiresAt      DateTime
  openedAt       DateTime?
  revokedAt      DateTime?
  createdAt      DateTime @default(now())
  file           File     @relation(fields: [fileId], references: [id])
  owner          User     @relation("ownerShares", fields: [ownerId], references: [id])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  ipAddress    String?
  userAgent    String?
  isActive     Boolean  @default(true)
  expiresAt    DateTime
  lastUsedAt   DateTime?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}
